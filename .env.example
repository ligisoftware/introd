# Supabase — get from team, or from https://supabase.com → project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (secret): used server-side only for /p/[slug] viewer (fetch founder by share_slug). Do not expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — for feedback form emails (https://resend.com/api-keys). Optional: RESEND_FROM_EMAIL (e.g. feedback@ligi.app).
RESEND_API_KEY=

# OpenAI — required for AI intro scores on /i/[slug] (https://platform.openai.com/api-keys). If missing, the score block shows "Summary temporarily unavailable".
OPENAI_API_KEY=

# E2E testing (optional) — only in development. Enables POST /api/e2e/session so AI agents or E2E runners can log in without magic link. Set E2E_TEST_MODE=true and create a test user in Supabase with email+password, then set:
# E2E_TEST_MODE=
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=

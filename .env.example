# Supabase — get from team, or from https://supabase.com → project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (secret): used server-side only for /p/[slug] viewer (fetch founder by share_slug). Do not expose to client.
SUPABASE_SERVICE_ROLE_KEY=

# Resend — for feedback form emails (https://resend.com/api-keys). Optional: RESEND_FROM_EMAIL (e.g. feedback@ligi.app).
RESEND_API_KEY=
